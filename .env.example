# OKE template local configuration
#
# Copy this file to .env and fill in the values for your own environment:
#   cp .env.example .env
#   $EDITOR .env
#
# .env is local-only and must never be committed.
# Values are shell-compatible. Use single quotes for secrets that contain special characters.

# OCI CLI profile and region.
# The helper reads tenancy/user/fingerprint/key path from ~/.oci/config using this profile.
OCI_PROFILE=DEFAULT
OCI_REGION=eu-stockholm-1
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1...

# OCI Object Storage bucket for OpenTofu state.
# just init creates this bucket if it does not exist and your OCI user has permission.
TOFU_STATE_BUCKET=terraform-state
TOFU_STATE_PREFIX=oke

# OCI Customer Secret Key pair for the S3-compatible Object Storage backend.
AWS_ACCESS_KEY_ID='<oci-customer-secret-key-access-key>'
AWS_SECRET_ACCESS_KEY='<oci-customer-secret-key-secret>'

# GitHub / Flux bootstrap.
GITHUB_OWNER=your-github-user-or-org
GITHUB_REPOSITORY=OKE
GITHUB_BRANCH=main
GITHUB_TOKEN='<github-token-with-repo-access>'

# Public DNS and TLS.
BASE_DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com

# Cloudflare DNS token used by cert-manager and external-dns.
CLOUDFLARE_API_TOKEN='<cloudflare-dns-token>'

# Optional OKE sizing defaults. Replace the API CIDR with your own IP/CIDR for real use.
CLUSTER_NAME=oke-cluster
NODE_POOL_NAME=pool1
NODE_COUNT=3
NODE_OCPUS=1
NODE_MEMORY_GBS=8
NODE_BOOT_VOLUME_SIZE_GBS=66
API_ENDPOINT_ALLOWED_CIDRS='["0.0.0.0/0"]'

# Optional generated names. Leave these empty unless you need stable custom names.
# Use EXTERNAL_DNS_TXT_OWNER_ID when reusing an existing DNS zone that already has
# ExternalDNS TXT ownership records from an older cluster.
EXTERNAL_DNS_TXT_OWNER_ID=
GATEWAY_TLS_SECRET_NAME=
# VAULT_DISPLAY_NAME=oke-vault
# VAULT_KEY_DISPLAY_NAME=oke-secrets-key
# CLOUDFLARE_API_TOKEN_SECRET_NAME=cloudflare-api-token
